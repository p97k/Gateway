{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "API Gateway",
  "uid": "api-gateway",
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s) by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service) (rate(gateway_requests_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (s) by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(gateway_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx error rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate(gateway_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate-limit rejections by scope",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (scope) (rate(gateway_rate_limit_rejections_total[1m]))",
          "legendFormat": "{{scope}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth & authz failures",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(gateway_authentication_failures_total[1m]))",
          "legendFormat": "authentication"
        },
        {
          "expr": "sum(rate(gateway_authorization_failures_total[1m]))",
          "legendFormat": "authorization"
        }
      ]
    }
  ]
}
